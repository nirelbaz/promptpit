{
  "name": "promptpit",
  "version": "0.1.1",
  "description": "Portable AI agent stacks — collect, install, and share across Claude Code, Cursor, and more",
  "type": "module",
  "bin": {
    "pit": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "cursor",
    "skills",
    "config",
    "portable"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "ora": "^9.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "memfs": "^4.56.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
